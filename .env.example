# AimBotz — Supabase (Next.js)
# Copy to .env.local and fill values. Never commit .env.local.

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: server-only admin key (Dashboard → Settings → API)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Auth redirect URLs to add in Supabase Dashboard → Authentication → URL Configuration:
#   Site URL: http://localhost:3000
#   Redirect URLs: http://localhost:3000/auth/callback
#
# Enable providers: Authentication → Providers → Google / Discord
